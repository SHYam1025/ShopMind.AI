# ── Required ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email (Gmail SMTP) ───────────────────
EMAIL_FROM=yourgmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME=ShopMind AI
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Payment (Optional) ──────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Optional ─────────────────────────────
SERPAPI_KEY=
APP_ENV=development
LOG_LEVEL=INFO
HEADLESS=true
REQUEST_TIMEOUT_SECONDS=20
MAX_SEARCH_RESULTS_PER_PLATFORM=5
DATABASE_URL=sqlite+aiosqlite:///./shopmind.db
